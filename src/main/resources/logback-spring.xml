<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Carpeta de logs -->
    <property name="LOG_PATH" value="logs" />

    <!-- Appender para consola general -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Appender exclusivo para sincronización de torneos -->
    <appender name="TOURNAMENTS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/tournaments-sync.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/tournaments-sync.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>10</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{60} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logger SOLO para tournaments -->
    <logger name="com.pronosticup.backend.tournaments" level="INFO" additivity="false">
        <appender-ref ref="TOURNAMENTS_FILE" />
    </logger>

    <!-- Root solo a consola -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>